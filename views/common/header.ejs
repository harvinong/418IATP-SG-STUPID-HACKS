<%# Variables %>
<% const pagelink = {
    Home: "/",
    "Play Game": "/game/",
    "Add Fake Post": "/game/add-fake",
    "Add Real Post": "/game/add-real",
    "Saw Real Post": "/game/saw-real"
} %>

<%# HTML Elements %>
<header>
    <nav>
         | 
        <% for (const page in pagelink) { %>
            <a href="<%= pagelink[page] %>"><%= page %></a> | 
        <% } %>
    </nav>
    <hr>
</header>