<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saw a Real Post? | LinkedOUT</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('common/header') %>
    
    <div class="container">
        <div class="card">
            <h1>Saw a Real Post?</h1>
            <p style="color: var(--text-muted); margin-bottom: 2rem;">Share a screenshot or text of a real LinkedIn post you encountered.</p>
            
            <form action="saw-real" method="post">
                <div class="form-group">
                    <label for="text">Post Content</label>
                    <textarea name="text" id="text" placeholder="Copy the text of the post here..."></textarea>
                </div>
                
                <div class="form-group">
                    <label for="link">Proof Link (Optional)</label>
                    <input type="text" name="link" id="link" placeholder="https://...">
                </div>
                
                <button type="submit" class="btn btn-primary">Submit Real Post Sighting</button>
            </form>
        </div>
    </div>

    <%- include('common/footer') %>
</body>
</html>